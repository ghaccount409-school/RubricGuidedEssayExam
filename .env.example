# Together.ai Project API key (create at https://api.together.ai/settings/api-keys — copy once, no quotes)
TOGETHER_API_KEY=

# The app always uses the built-in recommended fast model (openai/gpt-oss-20b) unless you opt in below.
# To use a custom Together chat model for every call, set TOGETHER_USE_ENV_MODEL=1 and set TOGETHER_MODEL to the API string
# (see https://docs.together.ai/docs/inference-models).
# TOGETHER_USE_ENV_MODEL=1
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Default server behavior; you can still pick Mock vs Production per exam on the home page.
# 1 = default to mock when opening the app; 0 = default to production when an API key is present.
MOCK_LLM=0

# Instructor dashboard: signing key for the session cookie (use a long random string in production).
# INSTRUCTOR_SESSION_SECRET=

# Optional: JSON path with one-way derived secrets (created on first run as instructor_credentials.json).
# INSTRUCTOR_CREDENTIALS_PATH=

# Optional overrides if you do not use a credentials file (hex SHA-256 of username UTF-8 bytes;
# hex PBKDF2-HMAC-SHA256 digest with salt "rgee-instructor-v1" and 210000 iterations).
# INSTRUCTOR_USERNAME_SHA256=
# INSTRUCTOR_PASSWORD_PBKDF2_HEX=
